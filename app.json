{
  "expo": {
    "name": "react-native-flora",
    "slug": "react-native-flora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reactnativeflora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.reactnativeflora"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-Light.ttf",
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-Regular.ttf",
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-Medium.ttf",
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-SemiBold.ttf",
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-Bold.ttf",
            "./assets/fonts/Plus_Jakarta_Sans/static/PlusJakartaSans-ExtraBold.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-Light.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-Regular.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-Medium.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-SemiBold.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-Bold.ttf",
            "./assets/fonts/Be_Vietnam_Pro/BeVietnamPro-ExtraBold.ttf",
            "./assets/fonts/Bad_Script/BadScript-Regular.ttf"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      "onnxruntime-react-native",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.reactnativeflora"
    }
  }
}
